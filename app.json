{
  "expo": {
    "name": "Belo Challenge",
    "slug": "belo-challenge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-light.png",
    "scheme": "belo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ezeed.belochallenge"
    },
    "android": {
      "package": "com.ezeed.belochallenge",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-light.png",
          "imageWidth": 200,
          "backgroundColor": "#FCFCFD",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#0B0B0D"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6b77cbf7-68e7-4801-a2e4-8603d908f0f6"
      }
    },
    "owner": "ezeed"
  }
}
